{
  "name": "fjg-note-navigator-toolbar",
  "version": "0.1.12",
  "description": "Custom Obsidian note toolbar for folder navigation, copy-location actions, recent notes, bookmarks, and project shortcuts.",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "lint": "npx eslint src/main.ts",
    "release": "node release.mjs",
    "stylelint": "npx stylelint 'src/Styles/styles.css'",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "keywords": [],
  "author": "Franklin Garrett",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/sortablejs": "^1.15.8",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "chokidar": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.38.0",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "obsidian": "latest",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@codemirror/view": "6.38.6",
    "sortablejs": "^1.15.2"
  }
}
